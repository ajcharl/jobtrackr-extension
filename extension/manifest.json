{
  "manifest_version": 3,
  "name": "JobTrackr",
  "version": "1.0.0",
  "description": "Track job applications automatically from LinkedIn, Indeed, and Workday",
  "permissions": ["scripting", "tabs", "storage", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://*.indeed.com/*", "https://*.indeed.ca/*", "https://*.indeed.co.uk/*", "https://*.indeed.co.in/*", "https://*.myworkday.com/*", "https://*.myworkdayjobs.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
